# Copy to .env for local development, or set these in your cloud host dashboard.

# Sign session cookies and CSRF tokens. Use a long random value in production.
SECRET_KEY=change-me-to-a-long-random-string

# Local default is SQLite. In the cloud, point this at Postgres or MySQL, e.g.
# DATABASE_URL=postgresql://user:password@host:5432/customs
DATABASE_URL=

# Set to 1 when the app is served over HTTPS so cookies are marked Secure.
SESSION_COOKIE_SECURE=0
